            }
          ]
        }
      },
      {
        "file_patterns": [
          "/*.sublime-project"
        ],
        "schema": {
          "properties": {
            "settings": {
              "properties": {
                "LSP": {
                  "properties": {
                    "LSP-prisma": {
                      "$ref": "sublime://settings/LSP-prisma#/definitions/PluginConfig"
                    }
                  }
                }
              }
